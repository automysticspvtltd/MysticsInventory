#!/usr/bin/env bash
# Org-scope safety check — blocks any commit that introduces a multi-tenant
# data leak (a Drizzle query, db.query relational call, or raw SQL touching
# an org-scoped table without an `organization_id` filter). See
# artifacts/api-server/scripts/check-org-scope.mjs for the full description
# and the `// org-scope-allow: <reason>` opt-out.
#
# Wired in automatically by the root `prepare` script (`git config
# core.hooksPath .githooks`) when you run `pnpm install`.
set -e

# Only run when relevant files (any workspace package's source, the db
# schema, or the linter itself) are part of the staged change — keeps
# unrelated commits fast. The script auto-discovers every workspace
# package that depends on `@workspace/db`, so the globs are intentionally
# broad here to catch new consumers without needing this hook to change.
changed=$(git diff --cached --name-only --diff-filter=ACMR \
  -- 'artifacts/*/src/**/*.ts' \
     'lib/*/src/**/*.ts' \
     'lib/integrations/*/src/**/*.ts' \
     'lib/db/src/schema/**/*.ts' \
     'artifacts/*/package.json' \
     'lib/*/package.json' \
     'lib/integrations/*/package.json' \
     'artifacts/api-server/scripts/check-org-scope.mjs' || true)

if [ -z "$changed" ]; then
  exit 0
fi

echo "pre-commit: running org-scope safety check..."
if ! pnpm --filter @workspace/api-server lint:org-scope; then
  echo ""
  echo "pre-commit: org-scope check failed — commit blocked."
  echo "Fix the violation above (add eq(<table>.organizationId, ...) to the"
  echo "WHERE clause), or, if the query intentionally crosses tenants, add a"
  echo "// org-scope-allow: <reason> comment on the offending line."
  exit 1
fi
